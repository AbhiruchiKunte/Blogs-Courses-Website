<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SciAstra Platform</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton+SC&family=Kanit:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Lobster&family=Oleo+Script&family=Spicy+Rice&display=swap" rel="stylesheet">    
    <style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Colors and Typography */
:root {
    --primary-color: #0B192C;
    --secondary-color: #50b3a2;
    --text-color: #555;
    --bg-light: #ffffff;
    --bg-dark: #f4f4f9;
}
body {
    font-family: 'Arial', sans-serif;
}

/* Navbar */
.navbar {
    position: fixed;
    width: 100%;
    top: 0;
    background-color: var(--primary-color);
    color: #fff;
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    z-index: 10;
}

.navbar .logo {
    font-size: 2em;
    font-weight: bold;
    color: #fff;
    font-family: "Lobster", serif;
    font-weight: 400;
    font-style: normal;
}

.navbar .nav-links {
    list-style: none;
    display: flex;
}

.nav-links li {
    margin: 0 15px;
}

.nav-links a {
    color: #fff;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
    font-size: 18px;
}

.nav-links a:hover,
.nav-links .active {
    color: var(--secondary-color);
}

.menu-toggle {
    display: none;
    font-size: 2rem;
    cursor: pointer;
}

/* Hero Section */
.hero {
    background: url('/Images/Free-galaxy-wallpapers.jpg') center/cover no-repeat;
    margin-top: 60px;
    color: white;
    text-align: center;
    padding: 8rem 1rem; /* Increased padding for better visibility */
    position: relative;
}

.hero h1 {
    color: #fff;
    font-size: 3rem;
    font-weight: 600;
    margin-bottom: 1rem;
    font-family: "Anton SC", sans-serif;
    font-weight: 400;
    font-style: normal;
    position: relative;
    top: -120px;
}

.hero p {
    margin-top: 0.5rem;
    font-size: 1.2rem;
    font-weight: 400;
    position: relative;
    bottom: -100px;
}

.hero-btn {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.75rem 2rem;
    background-color: var(--secondary-color);
    color: white;
    border: none;
    border-radius: 5px;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 500;
    transition: background-color 0.3s ease;
}

.hero-btn:hover {
    background-color: #3e8e81;
}

/* General Section Styling */
.section {
    padding: 4rem 2rem;
    text-align: center;
    background-color: var(--bg-light);
}

.section h2 {
    margin-bottom: 1.5rem;
    color: var(--primary-color);
    font-size: 2.5rem;
    font-weight: 600;
    position: relative;
    top: 20px;
}

/* Swiper Container */
.swiper-container {
    padding: 2rem 0;
    width: 100%;
    position: relative;
}

/* Swiper Wrapper */
.swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
}

/* Swiper Slide */
.swiper-slide {
    display: flex;
    justify-content: center;
    max-width: 25%; /* Limit to 4 slides per view */
    box-sizing: border-box;
    padding: 0 10px;
}

/* Centering Swiper Slides */
.swiper-slide {
    margin-right: auto;
    margin-left: auto;
}

/* Card Styling */
.card {
    background-color: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    width: 100%;
    max-width: 300px;
    height: 100%; /* Make sure cards have consistent height */
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    margin-left: 20px;
}

/* Card Hover Effect */
.card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15);
}

/* Card Image */
.card img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: 8px;
}

/* Card Title */
.card h3 {
    margin-top: 1rem;
    color: var(--primary-color);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.3;
    height: 3rem; /* Set height to limit text */
    overflow: hidden; /* Hide excess text */
}

/* Card Description */
.card p {
    font-size: 0.9rem;
    color: #777;
    margin: 0.5rem 0;
    line-height: 1.4;
    max-height: 3rem; /* Limit height of description */
    overflow: hidden; /* Hide excess text */
}

/* Button Styling Inside Card */
.card button {
    margin-top: auto; /* Push button to the bottom */
    padding: 0.7rem 1.5rem;
    background-color: var(--primary-color);
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    transition: background-color 0.3s ease;
}

.card button:hover {
    background-color: var(--secondary-color);
}

/* Swiper Pagination */
.swiper-pagination {
    position: absolute;
    bottom: -30px; /* Position below the navigation buttons */
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: var(--primary-color);
}

/* Swiper Navigation Buttons */
.swiper-button-next, .swiper-button-prev {
    color: var(--primary-color);
    border-radius: 50%;
    padding: 0.8rem;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
}

.swiper-button-next {
    right: 10px;
}

.swiper-button-prev {
    left: 10px;
}

.swiper-button-next:hover, .swiper-button-prev:hover {
    color: var(--secondary-color);
}

/* Swiper Pagination Bullets */
.swiper-pagination-bullet {
    background-color: var(--primary-color);
    z-index: -1;
}

.swiper-pagination-bullet-active {
    background-color: var(--secondary-color);
}

/* Responsive Adjustments */
@media (max-width: 1024px) {
    .swiper-slide {
        max-width: 50%; /* Show 2 slides per view on medium screens */
    }
}

@media (max-width: 768px) {
    .swiper-slide {
        max-width: 100%; /* Show 1 slide per view on smaller screens */
    }
}

@media (max-width: 640px) {
    .swiper-container {
        padding: 1rem 0;
    }
    .swiper-pagination {
        bottom: -20px; /* Adjust pagination position for smaller screens */
    }
}

 /* Footer */
 .footer {
    background-color: var(--primary-color);
    color: white;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.footer a {
    text-decoration: none;
    color: white;
    transition: color 0.3s ease;
}

.footer a:hover {
    color: var(--secondary-color);
}

#mail_id {
    font-size: 1.1rem;
    margin-bottom: 20px;
}

#three_div {
    display: flex;
    gap: 15px;
}

.social_icon {
    font-size: 24px;
    color: #fff; 
    transition: color 0.3s, transform 0.3s; 
}

.social_icon:hover {
    color: var(--secondary-color); 
    transform: scale(1.2); 
}

.two_footer {
    display: flex;
    justify-content: space-between;
    width: 80%;
    margin-top: 2rem;
    flex-wrap: wrap;
}

.left, .mid, .right {
    width: 30%;
    text-align: left;
}

.left h2, .mid h2, .right h2 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
}

#sub_link {
    display: block;
    color: white;
    text-decoration: none;
    margin-bottom: 8px;
    font-size: 1rem;
}

#sub_link:hover {
    color: var(--secondary-color);
}

 /*Contact Section Styling */
        #contact {
            padding: 50px;
            text-align: center;
            background-color: var(--bg-dark);
        }

        .contact-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        h1 {
            color: var(--primary-color);
            font-size: 36px;
            margin-top: 40px;
        }

.contact-details {
    background-color: var(--bg-dark);
    width: 600px;
    padding: 20px;
    border: none;
    margin: 20px;
    display: flex;
    align-items: center;
    flex-direction: column;
}

.contact-details p {
    margin: 10px 0;
}

.contact-details a {
    margin: 10px 0;
}

.contact-details button {
    margin: 10px 0;
}

.contact-email {
    color: #007BFF; 
    text-decoration: none;
    font-weight: bold;
}

.contact-email:hover {
    text-decoration: underline;
}

.contact-buttons {
    display: flex;
    justify-content: center; /* Center the buttons horizontally */
    gap: 10px; 
}
button {
    background-color: var(--primary-color); 
    color: white;
    border: none;
    border-radius: 5px;
    padding: 10px 15px;
    margin: 5px;
    cursor: pointer;
    font-size: 16px;
    transition: background-color 0.3s ease;
}

button:hover {
    background-color: var(--secondary-color);
}

button i {
    margin-right: 5px; 
}

.contact-form {
    max-width: 600px;
    width: 100%;
    background: var(--bg-light);
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
}

        .contact-form input, .contact-form textarea {
            width: 100%;
            padding: 10px;
            margin-bottom: 15px;
            border: 1px solid #ccc;
            border-radius: 4px;
            outline: none;
        }

        .contact-form label {
            display: block;
            margin-bottom: 5px;
            color: var(--text-color);
            font-weight: bold;
            text-align: left;
        }

        .contact-form input[type="checkbox"] {
            width: auto;
        }

        .contact-form button {
            width: 100%;
            padding: 12px;
            background-color: var(--primary-color);
            color: #fff;
            font-size: 16px;
            font-weight: bold;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        .contact-form button:hover {
            background-color: var(--secondary-color);
        }

.privacy-policy {
    max-width: 600px;
    margin: 50px auto;
    padding: 20px;
    text-align: left;
    color: var(--text-color);
    background-color: var(--bg-dark);
    border: none;
}

.privacy-policy h2 {
    color: var(--primary-color);
    margin-bottom: 20px;
    font-size: 2em;
    border-bottom: 2px solid var(--primary-color);
    padding-bottom: 10px;
}

.privacy-policy p {
    font-size: 1.1em;
    line-height: 1.6;
    margin-bottom: 15px;
    color: var(--text-color);
}

html {
    scroll-behavior: smooth;
}
/* Styling for the pop-up modal */
        #adminModal {
            display: none; /* Hidden by default */
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
        }
        .modal-content {
            background-color: #fff;
            margin: 15% auto;
            padding: 20px;
            border-radius: 5px;
            width: 300px;
            text-align: center;
        }
        .modal-content input {
            margin: 10px 0;
            padding: 8px;
            width: 80%;
        }
        .modal-content button {
            padding: 8px 16px;
            cursor: pointer;
        }

/* Responsive Design */
@media (max-width: 768px) {
    .nav-links {
        display: none;
        flex-direction: column;
        width: 100%;
    }

    .menu-toggle {
        display: block;
    }

    .show {
        display: flex;
    }

    .hero h1 {
        font-size: 2rem;
    }

    .hero p {
        font-size: 1rem;
    }

    .hero-btn {
        font-size: 1rem;
    }
}
    </style>
</head>
<body>
    
    <!-- Navbar -->
<div class="navbar">
        <div class="logo">SciAstra</div>
<ul class="nav-links">
        <li><a href="#home">Home</a></li>
        <li><a href="#blogs">Blog</a></li>
        <li><a href="#free-courses">Courses</a></li>
        <li><a href="#contact">Contact</a></li>
        <li><a href="#" onclick="showAdminModal()">Add New</a></li>
</ul>

<!--Modal for admin login-->
<div id="adminModal">
    <div class="modal-content">
        <h3>Admin Panel</h3>
        <label for="username">Username:</label><br>
        <input type="text" id="username" placeholder="Enter username"><br>
        <label for="password">Password:</label><br>
        <input type="password" id="password" placeholder="Enter password"><br>
        <button onclick="validateAdmin()">Submit</button>
        <button onclick="closeModal()">Cancel</button>
    </div>
</div>
        <div class="menu-toggle" onclick="toggleMenu()">&#9776;</div>
    </div>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <h1>Welcome to SciAstra</h1>
        <p>Discover the best courses at discounted prices and stay updated with our latest blogs!</p>
    </section>
    
<!-- Blog Section -->
<section id="blogs" class="section">
    <h2>Latest Blogs</h2>

    <!-- Include Swiper CSS -->
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />
    <div class="swiper-container">
        <div class="swiper-wrapper" id="blog-list">
            <% 
            const blogs = [
                {
                    Blog_img: '/Images/Futureofai.jpeg',
                    Blog_title: 'The Future of AI',
                    Blog_description: 'Exploring the advancements and ethics in Artificial Intelligence.',
                    created_at: '2024-11-07T10:30:00'
                },
                {
                    Blog_img: '/Images/Webdev.jpeg',
                    Blog_title: 'Web Development Trends 2024',
                    Blog_description: 'A look into the latest trends in the web development industry.',
                    created_at: '2024-11-05 08:15 AM'
                },
                {
                    Blog_img: '/Images/Future-of-Cyber-Security-in-Digital-Space.jpg',
                    Blog_title: 'Cybersecurity in a Digital World',
                    Blog_description: 'How to protect your data in an increasingly digital world.',
                    created_at: '2024-10-28 03:45 PM'
                },
                {
                    Blog_img: '/Images/Blockchain-beyond-Bitcoin.jpeg',
                    Blog_title: 'Blockchain Beyond Bitcoin',
                    Blog_description: 'Exploring the various applications of blockchain technology.',
                    created_at: '2024-10-20 05:20 PM'
                },
                {
                    Blog_img: '/Images/RemoteWork.jpeg',
                    Blog_title: 'The Rise of Remote Work',
                    Blog_description: 'Analyzing the impact of remote work on productivity and culture.',
                    created_at: '2024-10-15 09:00 AM'
                }
            ];

            blogs.forEach(blog => { 
            %>
                <div class="swiper-slide">
                    <div class="card">
                        <!-- Blog Image -->
                        <img src="<%= blog.Blog_img %>" alt="<%= blog.Blog_title %>" style="width: 250px; height: 200px !important; object-fit: contain; margin-top: -20px;;">
                        <!-- Blog Title -->
                        <h3><%= blog.Blog_title %></h3>
                        
                        <!-- Blog Description -->
                        <p><%= blog.Blog_description %></p>

                        <!-- Published Date -->
                        <p class="created-at">Published at: <%= blog.created_at %></p>
                    </div>
                </div>
            <% }); %>
        </div>
        <div class="swiper-pagination"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
    </div>

    <!-- Swiper JavaScript -->
    <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const swiper = new Swiper('.swiper-container', {
                loop: true,
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                slidesPerView: 3, 
                spaceBetween: 5,
                breakpoints: {
                    640: { slidesPerView: 1 },
                    768: { slidesPerView: 2 },
                    1024: { slidesPerView: 3 },
                    1200: { slidesPerView: 4 },
                },
            });
        });
    </script>
</section>

<!-- Free Courses Section -->
<section id="free-courses" class="section">
    <h2>Free Courses</h2>

    <!-- Include Swiper CSS -->
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />

    <div class="swiper-container" id="free-course-swiper">
    <div class="swiper-wrapper" id="free-course-list">
        <% 
        const freeCourses = [
            {
                course_img: '/Images/Introduction-to-HTML.jpeg',  // Path to the image in public/images folder
                coursename: 'Introduction to HTML',
                course_type: 'Beginner Level',
            },
            {
                course_img: '/Images/CSS-Tutorial.jpeg',  // Path to the image in public/images folder
                coursename: 'CSS for Beginners',
                course_type: 'Beginner Level',
            },
            {
                course_img: '/Images/Javascript Basic.jpeg',  // Path to the image in public/images folder
                coursename: 'JavaScript Basics',
                course_type: 'Intermediate Level',
            },
            {
                course_img: '/Images/Responsive web design.jpg',  // Path to the image in public/images folder
                coursename: 'Responsive Web Design',
                course_type: 'Intermediate Level',
            },
            {
                course_img: '/Images/Introduction-to-Python.jpg',  // Path to the image in public/images folder
                coursename: 'Intro to Python Programming',
                course_type: 'Beginner Level',
            }
        ];

        freeCourses.forEach(course => { 
        %>
            <div class="swiper-slide">
                <div class="card">
                    <!-- Use the dynamic course_img URL here -->
                    <img src="<%= course.course_img %>" alt="<%= course.coursename %>" style="width: 250px; height: 200px !important; object-fit: contain; margin-top: -20px;;">
                    <h3><%= course.coursename %></h3>
                    <p><%= course.course_type %></p>
                    <p>Price: Free</p>
                    <button onclick="window.location.href='/course-details/<%= course.coursename.replace(/\s+/g, '-').toLowerCase() %>'">Learn More</button>
                </div>
            </div>
        <% }); %>
    </div>
    <div class="swiper-pagination"></div>
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
</div>


    <!-- External JS and Swiper setup -->
    <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
    <script>
        const swiperFree = new Swiper('#free-course-swiper', {
            loop: true,
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            },
            navigation: {
                nextEl: '.swiper-button-next',
                prevEl: '.swiper-button-prev',
            },
            slidesPerView: 4, 
            spaceBetween: 5,
            breakpoints: {
                640: {
                    slidesPerView: 1,
                },
                768: {
                    slidesPerView: 2,
                },
                1024: {
                    slidesPerView: 3,
                },
                1200: {
                    slidesPerView: 4,
                },
            },
        });
    </script>
</section>

<!-- Paid Courses Section -->
<section id="paid-courses" class="section">
    <h2>Paid Courses</h2>

    <!-- Include Swiper CSS -->
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />

    <div class="swiper-container" id="paid-course-swiper">
        <div class="swiper-wrapper" id="paid-course-list">
            <% 
            const paidCourses = [
                {
                    course_img: '/Images/Adv Javascript.jpg',
                    coursename: 'Advanced JavaScript',
                    course_type: 'Advanced Level',
                    price: 49.99
                },
                {
                    course_img: '/Images/react and redux.jpeg',
                    coursename: 'React & Redux Masterclass',
                    course_type: 'Intermediate Level',
                    price: 59.99
                },
                {
                    course_img: '/Images/Python-for-Data-Science.jpg',
                    coursename: 'Python for Data Science',
                    course_type: 'Advanced Level',
                    price: 79.99
                },
                {
                    course_img: '/Images/Machine learning basics.jpg',
                    coursename: 'Machine Learning Basics',
                    course_type: 'Intermediate Level',
                    price: 69.99
                },
                {
                    course_img: '/Images/Webdev.jpeg',
                    coursename: 'Web Development Bootcamp',
                    course_type: 'Beginner Level',
                    price: 39.99
                }
            ];

            paidCourses.forEach(course => { 
            %>
                <div class="swiper-slide">
                    <div class="card">
                         <!-- Use the dynamic course_img URL here -->
                        <img src="<%= course.course_img %>" alt="<%= course.coursename %>" style="width: 250px; height: 200px !important; object-fit: contain; margin-top: -20px;;">
                        <h3><%= course.coursename %></h3>
                        <p><%= course.course_type %></p>
                        <p>Price: ₹<%= course.price %></p>
                        <!-- Add enroll now button -->
                        <button onclick="enrollNow('<%= course.coursename %>', '<%= course.price %>')">Enroll now</button>
                    </div>
                </div>
            <% }); %>
        </div>
        <div class="swiper-pagination"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
    </div>
</section>

<!-- Include Razorpay Checkout Script -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
    // Function to handle 'Enroll now' button click
    function enrollNow(courseName, price) {
        // Send a request to create an order
        fetch('/createOrder', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                amount: price,
                name: courseName,
                description: 'Course Payment'
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                var options = {
                    key: data.key_id,
                    amount: data.amount,
                    currency: 'INR',
                    name: data.name,
                    description: data.description,
                    image: 'https://www.example.com/logo.png',
                    order_id: data.order_id,
                    handler: function (response) {
                        alert('Payment successful');
                        // You can handle post-payment success logic here
                    },
                    prefill: {
                        name: data.name,
                        email: data.email,
                        contact: data.contact
                    },
                    notes: {
                        address: 'Razorpay Corporate Office'
                    },
                    theme: {
                        color: '#F37254'
                    }
                };
                var rzp1 = new Razorpay(options);
                rzp1.open();
            } else {
                alert('Order creation failed. Please try again!');
            }
        })
        .catch(error => console.error('Error:', error));
    }
</script>
